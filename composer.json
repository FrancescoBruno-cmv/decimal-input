{
    "name": "francescobruno-cmv/decimal-input",
    "description": "A Blade component for decimal number input with Alpine.js, supporting Laravel classic forms (name) and Livewire (wire:model / wire:model.live).",
    "type": "library",
    "keywords": ["laravel", "blade", "component", "decimal", "input", "livewire", "alpinejs"],
    "license": "MIT",
    "authors": [
        {
            "name": "Francesco Bruno",
            "email": "f.bruno@cmvgroup.it"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "FrancescoBrunoCmv\\DecimalInput\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "FrancescoBrunoCmv\\DecimalInput\\DecimalInputServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
